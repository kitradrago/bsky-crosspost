<?xml version="1.0" encoding="utf-8"?>
<Container version="2">
  <Name>Bluesky-Crosspost</Name>
  <Repository>kitradrago/bsky-crosspost</Repository>
  <Registry>https://hub.docker.com</Registry>
  <Network>bridge</Network>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/kitradrago/bsky-crosspost</Support>
  <Project>https://github.com/kitradrago/bsky-crosspost</Project>
  <Overview>Automatically crosspost Bluesky posts to Telegram, Discord, and FurAffinity</Overview>
  <Category>MediaServer</Category>
  <WebUI>https://[IP]:[PORT:2759]</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/kitradrago/bsky-crosspost/main/bsky-crosspost.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/kitradrago/bsky-crosspost/main/icon.png</Icon>
  <ExtraParams></ExtraParams>
  <PostArgs></PostArgs>
  <DonateText></DonateText>
  <DonateLink></DonateLink>
  <Description>
Bluesky Crosspost Manager automatically monitors a Bluesky account and crossposting posts to multiple platforms:
- Telegram
- Discord  
- FurAffinity

Features:
- Web UI for easy configuration
- Manual post checking and selective crossposting
- Activity log with post history
- Enable/disable individual services as needed
  </Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>2759</HostPort>
        <ContainerPort>2759</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Environment>
    <Variable>
      <Name>BLUESKY_HANDLE</Name>
      <Value>your_handle.bsky.social</Value>
      <Description>Your Bluesky handle</Description>
      <Mode></Mode>
    </Variable>
    <Variable>
      <Name>BLUESKY_PASSWORD</Name>
      <Value></Value>
      <Description>Your Bluesky app password (generate at https://bsky.app/settings/app-passwords)</Description>
      <Mode></Mode>
    </Variable>
    <Variable>
      <Name>BLUESKY_TARGET_HANDLE</Name>
      <Value></Value>
      <Description>The Bluesky account to monitor (can be same as BLUESKY_HANDLE)</Description>
      <Mode></Mode>
    </Variable>
    <Variable>
      <Name>BLUESKY_CHECK_INTERVAL</Name>
      <Value>300</Value>
      <Description>How often to check for new posts in seconds (default: 300 = 5 minutes)</Description>
      <Mode></Mode>
    </Variable>
    <Variable>
      <Name>TELEGRAM_ENABLED</Name>
      <Value>false</Value>
      <Description>Enable Telegram crossposting (true/false)</Description>
      <Mode></Mode>
    </Variable>
    <Variable>
      <Name>TELEGRAM_BOT_TOKEN</Name>
      <Value></Value>
      <Description>Your Telegram bot token</Description>
      <Mode></Mode>
    </Variable>
    <Variable>
      <Name>TELEGRAM_CHANNEL_ID</Name>
      <Value></Value>
      <Description>Your Telegram channel ID (format: -1001234567890)</Description>
      <Mode></Mode>
    </Variable>
    <Variable>
      <Name>DISCORD_ENABLED</Name>
      <Value>false</Value>
      <Description>Enable Discord crossposting (true/false)</Description>
      <Mode></Mode>
    </Variable>
    <Variable>
      <Name>DISCORD_BOT_TOKEN</Name>
      <Value></Value>
      <Description>Your Discord bot token</Description>
      <Mode></Mode>
    </Variable>
    <Variable>
      <Name>DISCORD_CHANNEL_ID</Name>
      <Value></Value>
      <Description>Your Discord channel ID</Description>
      <Mode></Mode>
    </Variable>
    <Variable>
      <Name>FURAFFINITY_ENABLED</Name>
      <Value>false</Value>
      <Description>Enable FurAffinity posting (true/false)</Description>
      <Mode></Mode>
    </Variable>
    <Variable>
      <Name>FURAFFINITY_USERNAME</Name>
      <Value></Value>
      <Description>Your FurAffinity username</Description>
      <Mode></Mode>
    </Variable>
    <Variable>
      <Name>FURAFFINITY_PASSWORD</Name>
      <Value></Value>
      <Description>Your FurAffinity password</Description>
      <Mode></Mode>
    </Variable>
    <Variable>
      <Name>LOG_LEVEL</Name>
      <Value>INFO</Value>
      <Description>Logging level (DEBUG, INFO, WARNING, ERROR)</Description>
      <Mode></Mode>
    </Variable>
  </Environment>
  <Volumes>
    <Volume>
      <HostDir>/mnt/user/appdata/bsky-crosspost</HostDir>
      <ContainerDir>/config</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Volumes>
  <Labels>
  </Labels>
  <UnaffiliatedSponsor>false</UnaffiliatedSponsor>
</Container>