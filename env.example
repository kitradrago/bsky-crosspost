# Bluesky Configuration
BLUESKY_HANDLE=your_handle.bsky.social
BLUESKY_PASSWORD=your_app_password
BLUESKY_TARGET_HANDLE=your_handle.bsky.social
BLUESKY_CHECK_INTERVAL=300

# Telegram Configuration
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# Discord Configuration
DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# FurAffinity Configuration
FURAFFINITY_ENABLED=false
FURAFFINITY_USERNAME=
FURAFFINITY_PASSWORD=
# SELENIUM_URL defaults to http://selenium:4444/wd/hub (set by docker-compose)

# Admin Configuration
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Application Configuration
LOG_LEVEL=INFO
CONFIG_DIR=./config